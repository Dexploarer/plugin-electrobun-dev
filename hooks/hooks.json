{
  "description": "Validates Electrobun-specific patterns before file writes and edits",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate-electrobun.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
